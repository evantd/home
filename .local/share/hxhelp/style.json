{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "7",
    "margin": 0
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "5",
    "bold": true
  },
  "h1": {
    "block_suffix": "\n",
    "prefix": " ",
    "suffix": " ",
    "color": "0",
    "background_color": "5",
    "bold": true
  },
  "h2": {
    "prefix": "▎ ",
    "color": "5",
    "bold": true
  },
  "h3": {
    "prefix": "▎ ",
    "color": "6",
    "bold": true
  },
  "h4": {
    "prefix": "▎ ",
    "color": "4",
    "bold": true
  },
  "h5": {
    "prefix": "▎ ",
    "color": "4",
    "bold": true
  },
  "h6": {
    "prefix": "▎ ",
    "color": "4",
    "bold": true
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true,
    "color": "3"
  },
  "strong": {
    "bold": true,
    "color": "1"
  },
  "hr": {
    "color": "8",
    "format": "\n--------\n"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "4",
    "underline": true
  },
  "link_text": {
    "color": "4",
    "bold": true
  },
  "image": {
    "color": "4",
    "underline": true
  },
  "image_text": {
    "color": "4",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "color": "2",
    "background_color": "0"
  },
  "code_block": {
    "color": "7",
    "margin": 2,
    "chroma": null
  },
  "table": {
    "center_separator": "┼",
    "column_separator": "│",
    "row_separator": "─"
  },
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n🠶 "
  },
  "html_block": {},
  "html_span": {}
}
